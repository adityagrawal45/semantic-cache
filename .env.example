# Copy this file to .env and fill in real values before running in a
# non-mock environment. Never commit your actual .env file.

# --- Service ---
APP_NAME=semantic-cache
LOG_LEVEL=INFO
API_PORT=8000

# --- Redis / RedisVL ---
REDIS_URL=redis://redis:6379
REDIS_INDEX_NAME=llm_cache_idx
REDIS_PREFIX=cache:
EMBEDDING_DIM=1536

# --- Similarity / caching behavior ---
SIMILARITY_THRESHOLD=0.95
MIN_SIMILARITY_THRESHOLD=0.80
MAX_SIMILARITY_THRESHOLD=0.999

# --- TTL policy (seconds) ---
TTL_SHORT_SECONDS=3600
TTL_LONG_SECONDS=86400
TTL_DEFAULT_SECONDS=21600

# --- Provider credentials (leave blank + set USE_MOCK_EMBEDDINGS=true for local dev) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
# If true, unrecognized model names fall back to Groq instead of OpenAI.
# Handy if Groq is the only key you have.
DEFAULT_TO_GROQ=false

# --- Embeddings ---
# Groq does not offer an embeddings endpoint, so semantic similarity lookups
# always use OpenAI embeddings (needs OPENAI_API_KEY) or the mock fallback
# below. If OPENAI_API_KEY is blank, mock embeddings are used automatically
# regardless of this flag.
EMBEDDING_MODEL=text-embedding-3-small
USE_MOCK_EMBEDDINGS=false

# --- Cost estimation (USD per 1K tokens) ---
COST_PER_1K_INPUT_TOKENS=0.0005
COST_PER_1K_OUTPUT_TOKENS=0.0015

# --- Grafana (docker-compose only) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
